# ── Required ────────────────────────────────────────────────────────────────

# GitHub personal access token — used to read the repo (README, file tree,
# key source files) so the AI understands the app BEFORE recording it.
# Create one at https://github.com/settings/tokens (public_repo scope is enough
# for public repos).
GITHUB_TOKEN=your_github_token_here

# GMI Cloud API key — one key covers everything generative:
#   - DeepSeek-V3 (demo planning, browser navigation, narration writing)
#   - ElevenLabs TTS v3 (voiceover)
#   - Seedream 5.0 Lite (title card image)
# Get one at https://cloud.gmi.ai
GMI_CLOUD_API_KEY=your_gmi_cloud_key_here

# Backblaze B2 bucket for storing generated videos and segments
B2_BUCKET=devfields-media
B2_PUBLIC_URL=https://f005.backblazeb2.com/file/devfields-media

# Backblaze B2 credentials (read by Genblaze's S3StorageBackend)
B2_KEY_ID=your_b2_key_id
B2_APP_KEY=your_b2_app_key

# ── Notes ───────────────────────────────────────────────────────────────────
# - No separate ElevenLabs account/key is needed; TTS goes through GMI Cloud.
# - Demo-account login credentials are NOT environment variables — they're
#   passed per-job through the UI/API and used only during recording.
